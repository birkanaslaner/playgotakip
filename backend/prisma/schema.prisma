generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STAFF
}

enum PricingType {
  SAATLIK
  SABIT
  PAKET
}

enum PaymentStatus {
  BEKLIYOR
  ODENDI
}

enum PaymentMethod {
  NAKIT
  KART
}

enum TableStatus {
  UYGUN
  DOLU
  PASIF
}

model User {
  id           Int      @id @default(autoincrement())
  fullName     String
  username     String   @unique
  passwordHash String
  role         Role     @default(STAFF)
  createdAt    DateTime @default(now())

  visits Visit[]
}

model Guardian {
  id        Int      @id @default(autoincrement())
  fullName  String
  phone     String
  note      String?
  createdAt DateTime @default(now())

  children Child[]
  visits   Visit[]
}

model Child {
  id         Int       @id @default(autoincrement())
  fullName   String
  birthDate  DateTime?
  note       String?
  createdAt  DateTime  @default(now())
  guardianId Int
  guardian   Guardian  @relation(fields: [guardianId], references: [id], onDelete: Cascade)

  visits Visit[]
}

model PricingPlan {
  id           Int         @id @default(autoincrement())
  name         String
  type         PricingType @default(SAATLIK)
  price        Float
  unitMinutes  Int         @default(60)
  playArea     String?
  label        String?
  weekdayPrice Float?
  weekendPrice Float?
  carryOver    Boolean     @default(false)
  loyalty      Boolean     @default(false)
  active       Boolean     @default(true)
  createdAt    DateTime    @default(now())

  visits Visit[]
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  products    Product[]
}

model Setting {
  key   String @id
  value String
}

model PlayArea {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
}

model Product {
  id            Int       @id @default(autoincrement())
  name          String
  price         Float     @default(0)
  stock         Int       @default(0)
  vatRate       Int       @default(10)
  image         String?
  active        Boolean   @default(true)
  showInQrMenu  Boolean   @default(true)
  qrDescription String?
  tags          String?
  categoryId    Int?
  category      Category? @relation(fields: [categoryId], references: [id])
  createdAt     DateTime  @default(now())
  tabItems      TabItem[]
}

model CafeTable {
  id        Int         @id @default(autoincrement())
  name      String      @unique
  status    TableStatus @default(UYGUN)
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())
  tabs      TableTab[]
}

model TableTab {
  id            Int            @id @default(autoincrement())
  tableId       Int
  table         CafeTable      @relation(fields: [tableId], references: [id], onDelete: Cascade)
  total         Float          @default(0)
  paidAmount    Float          @default(0)
  paymentMethod PaymentMethod?
  openedAt      DateTime       @default(now())
  closedAt      DateTime?
  items         TabItem[]
}

model TabItem {
  id        Int       @id @default(autoincrement())
  tabId     Int
  tab       TableTab  @relation(fields: [tabId], references: [id], onDelete: Cascade)
  productId Int
  product   Product   @relation(fields: [productId], references: [id])
  quantity  Int       @default(1)
  unitPrice Float
  vatRate   Int       @default(10)
  lineTotal Float
  createdAt DateTime  @default(now())

  @@unique([tabId, productId])
}

model Visit {
  id            Int            @id @default(autoincrement())
  childId       Int
  child         Child          @relation(fields: [childId], references: [id])
  guardianId    Int
  guardian      Guardian       @relation(fields: [guardianId], references: [id])
  pricingPlanId Int
  pricingPlan   PricingPlan    @relation(fields: [pricingPlanId], references: [id])
  wristbandNo     String
  checkInAt       DateTime       @default(now())
  checkOutAt      DateTime?
  durationMin     Int?
  discount        Float          @default(0)
  extraMinutes    Int            @default(0)
  extraCharge     Float          @default(0)
  pausedAt        DateTime?
  pausedMs        Int            @default(0)
  membershipMonths Int?
  membershipEndAt DateTime?
  amount          Float?
  paymentStatus PaymentStatus  @default(BEKLIYOR)
  paymentMethod PaymentMethod?
  staffId       Int?
  staff         User?          @relation(fields: [staffId], references: [id])
  createdAt     DateTime       @default(now())
}
